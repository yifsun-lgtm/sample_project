  "groups": [
    {
      "id": "group-procurement",
      "name": "調達部門",
      "path": "/調達部門",
      "subGroups": [
        {
          "id": "group-procurement-domestic",
          "name": "国内調達課",
          "path": "/調達部門/国内調達課"
        },
        {
          "id": "group-procurement-overseas",
          "name": "海外調達課",
