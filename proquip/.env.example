# ============================================================
# ProQuip 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください
#
# 使い方: cp .env.example .env
# 注意: .env ファイルはGitにコミットしないこと
# ============================================================

# -------------------------------------------------
# PostgreSQL データベース設定
# -------------------------------------------------
POSTGRES_DB=proquip
POSTGRES_USER=proquip
# TODO: 本番環境では強力なパスワードを設定すること
POSTGRES_PASSWORD=proquip

# アプリケーション用DB接続情報
DB_HOST=postgres
DB_PORT=5432
DB_NAME=proquip
DB_USER=proquip
DB_PASSWORD=proquip

# -------------------------------------------------
# Keycloak 認証サーバー設定
# -------------------------------------------------
KEYCLOAK_ADMIN=admin
# FIXME: デフォルトパスワードがそのまま使われるリスクがある
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=proquip
KEYCLOAK_CLIENT_ID=proquip-api

# -------------------------------------------------
# WildFly アプリケーションサーバー設定
# -------------------------------------------------
JAVA_OPTS=-Xms512m -Xmx1024m

# -------------------------------------------------
# メール送信設定（通知機能用）
# -------------------------------------------------
MAIL_ENABLED=false
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@proquip.example.com

# -------------------------------------------------
# ログレベル設定
# -------------------------------------------------
# DEBUG, INFO, WARN, ERROR
LOG_LEVEL=DEBUG

# -------------------------------------------------
# その他のアプリケーション設定
# -------------------------------------------------
# ファイルアップロード最大サイズ（バイト）
UPLOAD_MAX_SIZE=10485760
# バッチ処理のチャンクサイズ
BATCH_SIZE=100
