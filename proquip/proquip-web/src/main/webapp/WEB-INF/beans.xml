<?xml version="1.0" encoding="UTF-8"?>
<!--
    CDI (Contexts and Dependency Injection) 設定ファイル。

    bean-discovery-mode="all" を指定し、全クラスをCDI管理対象とする。
    Jakarta EE 10 のデフォルトは "annotated" だが、既存コードとの互換性のため
    "all" を明示的に指定している。

    技術的負債: "annotated" に変更し、必要なクラスにのみ
    @ApplicationScoped 等のスコープアノテーションを付与すべき。
-->
<beans xmlns="https://jakarta.ee/xml/ns/jakartaee"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                           https://jakarta.ee/xml/ns/jakartaee/beans_4_0.xsd"
       version="4.0"
       bean-discovery-mode="all">
</beans>
