<?xml version="1.0" encoding="UTF-8"?>
<ejb-jar xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/ejb-jar_4_0.xsd"
         version="4.0">

    <description>ProQuip EJBモジュール - インターセプター定義</description>

    <interceptors>
        <!-- 監査ログインターセプター -->
        <interceptor>
            <interceptor-class>com.proquip.ejb.interceptor.AuditInterceptor</interceptor-class>
        </interceptor>

        <!-- パフォーマンス監視インターセプター -->
        <interceptor>
            <interceptor-class>com.proquip.ejb.interceptor.PerformanceInterceptor</interceptor-class>
        </interceptor>

        <!-- トランザクションログインターセプター -->
        <interceptor>
            <interceptor-class>com.proquip.ejb.interceptor.TransactionLoggingInterceptor</interceptor-class>
        </interceptor>

        <!-- セキュリティインターセプター -->
        <interceptor>
            <interceptor-class>com.proquip.ejb.interceptor.SecurityInterceptor</interceptor-class>
        </interceptor>
    </interceptors>

    <assembly-descriptor>
        <interceptor-binding>
            <ejb-name>*</ejb-name>
            <interceptor-class>com.proquip.ejb.interceptor.TransactionLoggingInterceptor</interceptor-class>
        </interceptor-binding>
    </assembly-descriptor>

</ejb-jar>
